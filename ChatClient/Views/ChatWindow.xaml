<Window x:Class="ChatClient.Views.ChatWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Chat" Height="520" Width="420"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="Chat Messages"
                   FontWeight="Bold" FontSize="16" Margin="2,0,0,8"/>

        <!-- Message list -->
        <ListBox Grid.Row="1" x:Name="MessagesList"
                 ItemsSource="{Binding Messages}"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 HorizontalContentAlignment="Stretch">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Margin="2,4">
                        <!-- e.g. "Peter (14:22)" -->
                        <TextBlock Text="{Binding Header}"
                                   FontWeight="Bold" Foreground="#2C3E50"/>
                        <!-- message body -->
                        <TextBlock Text="{Binding Text}" TextWrapping="Wrap"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Input row -->
        <Grid Grid.Row="2" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBox Grid.Column="0" x:Name="MessageTextBox"
                     Text="{Binding NewMessage, UpdateSourceTrigger=PropertyChanged}"
                     FontSize="14" Padding="5" VerticalContentAlignment="Center"
                     KeyDown="MessageTextBox_KeyDown"/>

            <Button Grid.Column="1" Content="Send" Width="75" Margin="8,0,0,0"
                    Command="{Binding SendCommand}" IsDefault="True"/>
        </Grid>
    </Grid>
</Window>
